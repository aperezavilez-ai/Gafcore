# Copia a .env.local o configura en Vercel → Settings → Environment Variables.
# Cliente (prefijo VITE_): visibles en el bundle; no pongas secretos aquí.

# --- Sitio público (opcional) ---
# Si el canónico es www o un preview: https://www.gafcore.com | https://tu-preview.vercel.app
# VITE_PUBLIC_SITE_URL=https://gafcore.com

# --- Supabase (cliente) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=  (si tu flujo lo usa)

# --- Pagos (cliente) ---
# VITE_PAYMENTS_CLIENT_TOKEN=

# --- Supabase (servidor / SSR) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (servidor): una de las opciones ---
# Opción A — URL completa + clave (OpenAI, Azure OpenAI, proxy propio, etc.)
# AI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# AI_API_KEY=
#
# Opción B — OpenRouter (recomendado si quieres varios modelos con un solo proveedor)
OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=https://gafcore.com
# OPENROUTER_APP_TITLE=GafCore
#
# Opción C — OpenAI directo
OPENAI_API_KEY=

# Modelos opcionales (slugs del proveedor; por defecto gemini flash + gpt-4o en código)
# AI_MODEL_FAST=
# AI_MODEL_DEEP=
# AI_SUPPORT_MODEL=

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
# ELEVENLABS_API_KEY_1=

# --- Stripe (secret keys de tu cuenta Stripe) ---
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=

# --- Paddle (API keys oficiales sandbox / live) ---
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=

# --- YouTube OAuth ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Otros (solo si usas la feature) ---
# REPLICATE_API_TOKEN=
# GAFCORE_ADMIN_CODE=
# MASTER_SIGNUP_CODE=
